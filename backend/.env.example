DATABASE_URL="postgresql://erp_user:erp_password@localhost:5432/erp_wms"
JWT_SECRET="erp-wms-jwt-secret-troque-em-producao"
JWT_EXPIRES_IN="8h"
REDIS_HOST="localhost"
REDIS_PORT=6379
PORT=3002
NODE_ENV=development

# DFe — Integração com SEFAZ (usar Focus NFe, NFe.io, etc.)
NFE_API_URL="https://homologacao.focusnfe.com.br/v2"
NFE_API_TOKEN="seu-token-aqui"
NFE_AMBIENTE="homologacao"   # homologacao | producao

# Asaas (Gateway de pagamento)
ASAAS_API_KEY="sua-api-key"
ASAAS_BASE_URL="https://sandbox.asaas.com/api/v3"

# SINTEGRA (validação de IE)
SINTEGRA_TOKEN="seu-token"

# Upload
UPLOAD_PATH="./uploads"
MAX_FILE_SIZE_MB=10

INTERNAL_WEBHOOK_TOKEN="dev-internal-token"
