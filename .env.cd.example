# Config do CD NODE (mini-PC do CD). Copie para ".env" ao lado do docker-compose.cd.yml:
#     cp .env.cd.example .env
# e edite os valores. NUNCA versione o .env real.

# Banco local do CD (pode manter os defaults).
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_DB=erp_wms

# OBRIGATÓRIO: segredo forte do JWT (invente uma string longa e aleatória).
JWT_SECRET=troque_por_um_segredo_longo_e_aleatorio

# Porta web que os PCs do CD vão acessar (80 = http://IP-do-mini-PC direto).
WEB_PORT=80

# Semear o banco na primeira subida (idempotente). Deixe true na P1 para ter
# dados de teste; mude para false quando a sincronização com a nuvem (P2) entrar.
SEED_ON_BOOT=true

# Reservado para P2/P3 (sincronização com a nuvem). Vazio por enquanto.
UPSTREAM_URL=
